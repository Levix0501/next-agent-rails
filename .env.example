# Auth.js v5 — required. Generate with `bunx auth secret`.
AUTH_SECRET=

# Future: external backend base URL (uncomment when wiring real API)
# BACKEND_URL=https://api.example.com

# Google Analytics 4 measurement ID. Set per-environment to enable GA
# (e.g. only in production). Leave blank to disable. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
